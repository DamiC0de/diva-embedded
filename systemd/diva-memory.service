[Unit]
Description=Diva Memory & Speaker ID Service (Mem0 + WeSpeaker)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/diva-current
ExecStart=/usr/bin/python3 /opt/diva-current/python/memory-service.py
Restart=on-failure
RestartSec=5
EnvironmentFile=/opt/diva-current/.env
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
