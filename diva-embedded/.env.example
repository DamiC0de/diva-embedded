# ============================================
# Diva Embedded — Configuration
# ============================================

# --- API Keys (required) ---
ANTHROPIC_API_KEY=sk-ant-xxx
GROQ_API_KEY=gsk_xxx
BRAVE_API_KEY=BSA_xxx

# --- LLM ---
LLM_MODEL=claude-haiku-4-5-20251001

# --- Local services (defaults work on Rock 5B+) ---
TTS_BASE_URL=http://localhost:8880
STT_LOCAL_URL=http://localhost:8881/v1/audio/transcriptions
AUDIO_SERVER_URL=http://localhost:9010
INTENT_URL=http://localhost:8882
QWEN_URL=http://localhost:8080
SEARXNG_URL=http://localhost:8888

# --- Audio device ---
AUDIO_INPUT_DEVICE=plughw:5
AUDIO_OUTPUT_DEVICE=plughw:5

# --- Home Assistant (optional) ---
# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=your_long_lived_access_token

# --- Caregiver notifications (optional) ---
# NTFY_URL=https://ntfy.sh
# NTFY_TOPIC=diva-alerts-family

# --- Mode ---
NODE_ENV=production
PORT=3001
