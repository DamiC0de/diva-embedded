# Claude API
ANTHROPIC_API_KEY=sk-ant-xxx

# Groq (STT)
GROQ_API_KEY=gsk_xxx

# Brave Search
BRAVE_API_KEY=BSA_xxx

# Piper TTS
TTS_BASE_URL=http://localhost:8880

# Audio devices (adapter selon arecord -L / aplay -L)
AUDIO_INPUT_DEVICE=plughw:1
AUDIO_OUTPUT_DEVICE=plughw:1

# AEC (echo cancellation)
EC_BINARY=/opt/ec/ec
EC_INPUT_FIFO=/tmp/ec.input
EC_OUTPUT_FIFO=/tmp/ec.output

# Wake word
WAKEWORD_SCRIPT=python/wakeword_server.py

# Whisper local fallback
WHISPER_CPP_PATH=/usr/local/bin/whisper-cpp
WHISPER_MODEL_PATH=/opt/models/ggml-base.bin

# Memory
MEMORY_DIR=data/memory

# Server
PORT=3001
NODE_ENV=production
